# ViloForge Agent preview — provider credentials (TEMPLATE)
#
# Copy to .preview.env (git-ignored) and fill in, or run: ./preview.sh seed
# These are passed to the preview container as env vars at runtime. They are
# NEVER committed, baked into the image, or written to the data volume.
#
# DeepSeek API key — https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Claude Code subscription token — generate with the Claude Code CLI:
#   claude setup-token
# (requires an active Claude subscription; the preview then uses YOUR subscription
# quota via the anthropic provider's claude-code OAuth path).
CLAUDE_CODE_OAUTH_TOKEN=

# Default model the preview boots with (switchable live in the dashboard):
#   deepseek-chat            — DeepSeek V3 (cheap, no thinking)
#   deepseek-reasoner        — DeepSeek R1
#   claude-sonnet-4-5        — via the Claude Code subscription (anthropic provider)
HERMES_MODEL=deepseek-chat
